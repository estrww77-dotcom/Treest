<Window x:Class="OpenSteam.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RedSea" Height="620" Width="980"
        WindowStartupLocation="CenterScreen" Background="Transparent"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0,16,0,8" Width="40" Height="32">
                            <TextBlock Text="✕" FontSize="12" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E01E37"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuRadioButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="leftBar" Width="3" HorizontalAlignment="Left"
                                    Background="Transparent" CornerRadius="0,2,2,0"/>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0" Margin="0">
                                <ContentPresenter VerticalAlignment="Center" Margin="28,0,16,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#0A0A0A"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="leftBar" Property="Background" Value="#E01E37"/>
                                <Setter TargetName="bg" Property="Background" Value="#0D0305"/>
                                <Setter Property="Foreground" Value="#E01E37"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashCardButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="#0D0D0D"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="#1A1A1A"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2A2A2A"/>
                                <Setter TargetName="border" Property="Background" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.8" Color="Black"/>
        </Grid.Effect>

        <Border x:Name="MainBorder" Background="#080808" CornerRadius="16" BorderThickness="1" BorderBrush="#141414">
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Background="Black" CornerRadius="16"
                                Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Background="#050505" Grid.Column="0" CornerRadius="16,0,0,16"
                        BorderThickness="0,0,1,0" BorderBrush="#101010">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Margin="24,28,24,24">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" Background="#E01E37" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="Red" Foreground="White" FontSize="18" FontWeight="ExtraBold"/>
                                    <Run Text="Sea" Foreground="#E01E37" FontSize="18" FontWeight="ExtraBold"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Nav Items -->
                        <StackPanel Grid.Row="1" Margin="0,8,0,0">
                            <RadioButton Content="Dashboard"   IsChecked="True" Style="{StaticResource MenuRadioButton}" GroupName="Menu" Click="NavHome_Click"/>
                            <RadioButton Content="Game Hub"                 Style="{StaticResource MenuRadioButton}" GroupName="Menu" Click="NavOnline_Click"/>
                            <RadioButton Content="Collection"               Style="{StaticResource MenuRadioButton}" GroupName="Menu" Click="NavLibrary_Click"/>
                            <RadioButton Content="Network"                  Style="{StaticResource MenuRadioButton}" GroupName="Menu" Click="NavByPass_Click"/>
                            <RadioButton Content="Tools"                    Style="{StaticResource MenuRadioButton}" GroupName="Menu" Click="NavExtra_Click"/>
                            <RadioButton Content="Settings"                 Style="{StaticResource MenuRadioButton}" GroupName="Menu" Click="NavSettings_Click"/>
                        </StackPanel>

                        <!-- Version -->
                        <TextBlock Grid.Row="2" x:Name="txtVersion" Text="v3.0.0" Foreground="#252525"
                                   FontSize="10" FontWeight="SemiBold" Margin="24,0,24,20"/>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Column="1">

                    <!-- Drag bar + Exit button -->
                    <Border Height="44" VerticalAlignment="Top" Background="Transparent"
                            MouseDown="Drag_MouseDown" Panel.ZIndex="10">
                        <Button x:Name="ExitButton" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Style="{StaticResource ExitButtonStyle}" Click="ExitButton_Click"/>
                    </Border>

                    <!-- Dynamic views go here -->
                    <ContentControl x:Name="DynamicContent" Margin="0,44,0,0" Visibility="Collapsed"/>

                    <!-- DASHBOARD -->
                    <Grid x:Name="HomeGrid" Margin="0,44,0,0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="480">

                            <!-- Header -->
                            <StackPanel Margin="0,0,0,28">
                                <TextBlock Text="Dashboard" Foreground="White" FontSize="22"
                                           FontWeight="Bold" HorizontalAlignment="Left"/>
                                <TextBlock Text="Manage your Steam configuration and settings"
                                           Foreground="#333333" FontSize="12" FontWeight="Normal"
                                           HorizontalAlignment="Left" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Primary Actions -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="patchButton" Grid.Column="0"
                                        Style="{StaticResource PrimaryAction}"
                                        Height="52" Margin="0,0,4,0"
                                        Click="patchButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⬡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White" Opacity="0.8"/>
                                        <TextBlock Text="Patch Steam" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="DeletePatchButton" Grid.Column="1"
                                        Style="{StaticResource DangerAction}"
                                        Height="52" Margin="4,0,0,0"
                                        Click="DeletePatchButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⬡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#E01E37" Opacity="0.8"/>
                                        <TextBlock Text="Delete Patch" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Secondary Actions -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ResetSteam" Grid.Column="0"
                                        Style="{StaticResource DashCardButton}"
                                        Height="48" Margin="0,0,4,0"
                                        Click="ResetSteam_Click">
                                    <TextBlock Text="Restart Steam" Foreground="#AAAAAA"/>
                                </Button>
                                <Button x:Name="Plugins" Grid.Column="1"
                                        Style="{StaticResource DashCardButton}"
                                        Height="48" Margin="4,0,0,0"
                                        Click="Plugins_Click">
                                    <TextBlock Text="Millennium + Plugin" Foreground="#AAAAAA"/>
                                </Button>
                            </Grid>

                            <!-- Custom Lua -->
                            <Button x:Name="ManualLuaButton"
                                    Style="{StaticResource DashCardButton}"
                                    Height="44" Margin="0,0,0,20"
                                    Click="ManualLua_Click">
                                <TextBlock Text="Load Custom LuaLoader" Foreground="#666666" FontSize="12"/>
                            </Button>

                            <!-- Version Toggle -->
                            <Border Background="#0A0A0A" CornerRadius="10" Padding="16,12"
                                    BorderThickness="1" BorderBrush="#141414" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Loader Version" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock x:Name="DefaultTxt" Text="Default" FontSize="11" FontWeight="Medium" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#E01E37"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=VersionToggle, Path=IsChecked}" Value="True">
                                                                <Setter Property="Foreground" Value="#333333"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text=" / " Foreground="#222222" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="AlternativeTxt" Text="Alternative" FontSize="11" FontWeight="Medium" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#333333"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=VersionToggle, Path=IsChecked}" Value="True">
                                                                <Setter Property="Foreground" Value="#E01E37"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <CheckBox x:Name="VersionToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="False" VerticalAlignment="Center"
                                              Checked="VersionToggle_Checked"
                                              Unchecked="VersionToggle_Checked"/>
                                </Grid>
                            </Border>

                            <!-- Status -->
                            <Border Background="#0A0A0A" CornerRadius="10" Padding="16,11"
                                    BorderThickness="1" BorderBrush="#141414">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StatusDot" Fill="#22C55E" Width="7" Height="7"
                                             Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ParcheEstado" Text="Status: System Ready"
                                               Foreground="#555555" FontSize="12" FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>

                    <!-- SETTINGS -->
                    <Grid x:Name="SettingsGrid" Margin="0,44,0,0" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0">
                            <StackPanel Margin="32,20,32,32">

                                <StackPanel Margin="0,0,0,28">
                                    <TextBlock Text="Settings" Foreground="White" FontSize="22"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Configure your RedSea experience"
                                               Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>

                                <TextBlock Text="GENERAL" Foreground="#333333" FontSize="10"
                                           FontWeight="Bold" Margin="0,0,0,10"/>

                                <Border Style="{StaticResource SettingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Delete patch on close" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Removes applied patches when the application is closed." Foreground="#444444" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="DeleteAutoPatch_" Style="{StaticResource ToggleSwitchStyle}" Grid.Column="1" VerticalAlignment="Center" Checked="DeleteAutoPatch" Unchecked="DeleteAutoPatch"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Auto-Patch on Launch" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Automatically applies the patch when the manager starts." Foreground="#444444" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AutoPatch_" Style="{StaticResource ToggleSwitchStyle}" Grid.Column="1" VerticalAlignment="Center" Checked="AutoPatch" Unchecked="AutoPatch"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Close Steam before Patching" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Ensures Steam is closed before applying any changes." Foreground="#444444" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CloseSteamPatch_" Style="{StaticResource ToggleSwitchStyle}" Grid.Column="1" VerticalAlignment="Center" Checked="CloseSteamPatch" Unchecked="CloseSteamPatch"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable NSFW Alert" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Prevents warning messages for content marked as NSFW." Foreground="#444444" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="DisableNFSWAlert_" Style="{StaticResource ToggleSwitchStyle}" Grid.Column="1" VerticalAlignment="Center" Checked="DisableNFSWAlert" Unchecked="DisableNFSWAlert"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Filter for Online Lua" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Enables filtering for games in the Online Lua section." Foreground="#444444" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="DisableFilter_" Style="{StaticResource ToggleSwitchStyle}" Grid.Column="1" VerticalAlignment="Center" Checked="DisableFilterToOnlineLua" Unchecked="DisableFilterToOnlineLua"/>
                                    </Grid>
                                </Border>

                                <TextBlock Text="STEAM" Foreground="#333333" FontSize="10"
                                           FontWeight="Bold" Margin="0,20,0,10"/>

                                <Border Style="{StaticResource SettingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable Web Helper" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Disables steamwebhelper.exe to save system resources." Foreground="#444444" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="DisableWebHelper_" Style="{StaticResource ToggleSwitchStyle}" Grid.Column="1" VerticalAlignment="Center" Checked="DisableWebHelper" Unchecked="DisableWebHelper"/>
                                    </Grid>
                                </Border>

                                <TextBlock Text="MAINTENANCE" Foreground="#333333" FontSize="10"
                                           FontWeight="Bold" Margin="0,20,0,10"/>

                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <Button Content="Backup Steam" Style="{StaticResource PrimaryAction}" Height="40" Margin="0,0,4,4" FontSize="12" Click="SteamBackup_Click" Background="#1A5218" BorderBrush="#1A5218"/>
                                    <Button Content="Clean Steam Cache" Style="{StaticResource DangerAction}" Height="40" Margin="4,0,0,4" FontSize="12" Click="CleanCache_Click"/>
                                    <Button Content="Backup Steam Config" Style="{StaticResource DangerAction}" Height="40" Margin="0,4,4,0" FontSize="12" Click="ConfigBackup_Click"/>
                                    <Button Content="Open Steam Folder" Style="{StaticResource DashCardButton}" Height="40" Margin="4,4,0,0" FontSize="12" Click="Folder_Click"/>
                                </UniformGrid>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
