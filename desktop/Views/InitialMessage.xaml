<UserControl x:Class="OpenSteam.Views.InitialMessage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40,20">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <Border Width="10" Height="10" Background="#E01E37" CornerRadius="3" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Red" Foreground="White" FontSize="24" FontWeight="ExtraBold"/>
                    <Run Text="Sea" Foreground="#E01E37" FontSize="24" FontWeight="ExtraBold"/>
                </TextBlock>
            </StackPanel>

            <TextBlock x:Name="InfoVersion" Text="v3.0.0"
                       Foreground="#222222" FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <TextBlock Text="Welcome" Foreground="White" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Background="#0A0A0A" CornerRadius="12" Padding="20,16"
                    BorderThickness="1" BorderBrush="#1A1A1A" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#1A0808" CornerRadius="4" Padding="6,3" Margin="0,0,8,0">
                            <TextBlock Text="NOTE" Foreground="#E01E37" FontSize="9" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Read before continuing" Foreground="#444444" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="12" LineHeight="20"
                               Text="It is recommended that you back up your Steam folder before making any changes. You can do this from Settings."/>
                </StackPanel>
            </Border>

            <Border Background="#0A0A0A" CornerRadius="12" Padding="20,16"
                    BorderThickness="1" BorderBrush="#1A1A1A" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#0A0F1A" CornerRadius="4" Padding="6,3" Margin="0,0,8,0">
                            <TextBlock Text="TIP" Foreground="#3B82F6" FontSize="9" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Not working?" Foreground="#444444" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="12" LineHeight="20"
                               Text="If something isn't working, try switching between &quot;Default&quot; and &quot;Alternative&quot; mode on the Dashboard."/>
                </StackPanel>
            </Border>

            <Button x:Name="BtnDontShow" Content="Don't show again"
                    Width="200" Height="40" HorizontalAlignment="Center"
                    Cursor="Hand" Click="BtnDontShow_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="8"
                                            BorderThickness="1" BorderBrush="#141414"
                                            Background="#0A0A0A">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="#2A2A2A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
