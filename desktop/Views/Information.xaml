<UserControl x:Class="OpenSteam.Views.Information"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="About" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="InfoVersion" Text="Version 3.0.0"
                       Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,6,0">

                <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="12"
                           LineHeight="20" Margin="0,0,0,20"
                           Text="RedSea Manager is a Steam companion application designed to improve your gaming experience."/>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="Game Management" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="Organize and manage your Steam game library from one clean interface."
                                   TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="Game Hub" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="Search and add games to your collection quickly and easily."
                                   TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="Network" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="Enable multiplayer support for your installed titles."
                                   TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
