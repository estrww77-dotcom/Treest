<UserControl x:Class="OpenSteam.Views.Information"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Information" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="InfoVersion" Text="Version 3.0.0"
                       Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,6,0">

                <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="12"
                           LineHeight="20" Margin="0,0,0,20"
                           Text="RedSea is an open-source patching layer for Steam that enables advanced game compatibility and Lua-based library management."/>

                <!-- Dev -->
                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="Developer" Foreground="#E01E37" FontWeight="SemiBold" FontSize="11"
                                   Margin="0,0,0,6" LetterSpacing="1"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#555555" FontSize="12"
                                   Text="Open source — created by Abrahamqb (Jbrequi)."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#333333" FontSize="12"
                                   Text="github.com/Abrahamqb/OpenSteam" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="CORE FEATURES" Foreground="#222222" FontSize="10"
                           FontWeight="Bold" Margin="0,20,0,12" LetterSpacing="2"/>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="Library Jailbreak" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="Unlocks the Steam library, allowing you to play games natively including titles loaded via Lua."
                                   TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="LuaLoader" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="Loads Lua files from external servers to access non-DRM titles. Note: Online play requires an Online Fix patch."
                                   TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414">
                    <StackPanel>
                        <TextBlock Text="Lua Script Generator" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="Fetches depot keys and manifest IDs from SteamProof to generate working Lua scripts automatically."
                                   TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
