<UserControl x:Class="OpenSteam.Views.OnlineLua"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E01E37"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C4182F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40,0">

            <!-- Header -->
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="Online Lua" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Search and download Lua scripts by AppID or name"
                           Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Search card -->
            <Border Background="#0A0A0A" CornerRadius="12" Padding="20"
                    BorderThickness="1" BorderBrush="#141414">
                <StackPanel>
                    <TextBlock Text="Game AppID or Name" Foreground="#444444"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,12">
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#1A1A1A">
                            <Border.Background>
                                <SolidColorBrush Color="#0D0D0D"/>
                            </Border.Background>
                        </Border>
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent"
                                 Foreground="White"
                                 FontSize="14"
                                 Padding="14,12"
                                 BorderThickness="0"
                                 SelectionBrush="#E01E37"
                                 CaretBrush="White"
                                 VerticalAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock IsHitTestVisible="False"
                                   Text="e.g. 730  or  Counter-Strike"
                                   VerticalAlignment="Center"
                                   Margin="15,0,0,0"
                                   Foreground="#2A2A2A"
                                   FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button x:Name="ButtonSearch" Height="46" Style="{StaticResource SearchButtonStyle}" Click="Search_Click">
                        <Grid>
                            <TextBlock x:Name="ButtonText" Text="Download Script" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="ButtonProgress" IsIndeterminate="True"
                                         Width="80" Height="3" Visibility="Collapsed"
                                         Foreground="White" Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Tip -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                <Border Background="#1A0A0A" CornerRadius="4" Padding="6,3">
                    <TextBlock Text="TIP" Foreground="#E01E37" FontSize="9" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="  Use SteamDB to find the correct AppID for any game."
                           Foreground="#333333" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
