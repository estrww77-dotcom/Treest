<UserControl x:Class="OpenSteam.Views.Extra"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Extras" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Useful tools and community resources"
                       Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,6,0">

                <TextBlock TextWrapping="Wrap" Foreground="#333333" FontSize="12"
                           LineHeight="20" Margin="0,0,0,16"
                           Text="These tools are provided for convenience. Use them responsibly and at your own risk."/>

                <!-- SteamCMD -->
                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="Steamcmd">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="SteamCMD" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Official lightweight command-line Steam client." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#0F1A0F" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                            <TextBlock Text="Official" Foreground="#22C55E" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- NLGL -->
                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="nlgl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="NLGL — Rockstar Launcher Bypass" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Nightlight Game Launcher for Rockstar Games titles." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- CreamInstaller -->
                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="craminstaller">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="CreamInstaller — DLC Unlocker" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Automatic DLC unlock installer and config generator." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Online-Fix -->
                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="onlinefix">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Online-fix.me — Multiplayer Bypass" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Patches for playing online multiplayer games." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Steam Achievement Manager -->
                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#1A0808"
                        Cursor="Hand" MouseDown="steamachievementmanager">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Steam Achievement Manager" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Manage achievements and stats. Use with caution." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1A0808" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                            <TextBlock Text="Caution" Foreground="#E01E37" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
