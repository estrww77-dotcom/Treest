<UserControl x:Class="OpenSteam.Views.Extra"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Tools" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Companion utilities for your games"
                       Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,6,0">

                <TextBlock TextWrapping="Wrap" Foreground="#333333" FontSize="12"
                           LineHeight="20" Margin="0,0,0,16"
                           Text="Additional utilities to enhance your experience."/>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="Steamcmd">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="SteamCMD" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Official lightweight command-line Steam client." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#0F1A0F" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                            <TextBlock Text="Official" Foreground="#22C55E" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="nlgl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="NLGL — Game Launcher" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Alternative launcher for Rockstar Games titles." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="craminstaller">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="CreamInstaller" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Automatic content installer and configuration manager." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="onlinefix">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Online-fix" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Multiplayer support patches for various titles." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <Border Background="#0A0A0A" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,6" BorderThickness="1" BorderBrush="#141414"
                        Cursor="Hand" MouseDown="steamachievementmanager">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Achievement Manager" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Manage your Steam achievements and statistics." TextWrapping="Wrap" Foreground="#444444" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="›" Foreground="#2A2A2A" FontSize="18" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
