<UserControl x:Class="OpenSteam.Views.OnlineByPass"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OpenSteam.Views"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Online Fix" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Select a game to search on Online-Fix"
                       Foreground="#333333" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Game grid -->
        <Border Grid.Row="1" Background="#050505" CornerRadius="12"
                BorderThickness="1" BorderBrush="#111111" Padding="8">
            <ListBox x:Name="GamesListBox" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" CornerRadius="8"
                                            Background="#0D0D0D"
                                            BorderThickness="1" BorderBrush="#141414"
                                            Width="128" Height="196" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding CoverUrl}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Opacity="0.9"/>
                                            <Border VerticalAlignment="Bottom"
                                                    Background="#D4000000" Padding="8,6">
                                                <TextBlock Text="{Binding name}" Foreground="White"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           TextAlignment="Center" TextWrapping="Wrap"
                                                           MaxHeight="38"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#E01E37"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2A2A2A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- Action -->
        <Button x:Name="BtnSearchOnlineFix" Grid.Row="2"
                Content="Search on Online-Fix" Height="44" Margin="0,12,0,0"
                Cursor="Hand" Foreground="White" FontSize="13" FontWeight="SemiBold"
                Click="BtnSearchOnlineFix_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" CornerRadius="8" BorderThickness="1"
                            BorderBrush="#E01E37" Background="#E01E37">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#C4182F"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
